{
  "version": 3,
  "configurePresets": [
    {
      "name": "msvc-release",
      "displayName": "MSVC Release",
      "description": "Windows MSVC Release 编译 (x64)",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build/msvc-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "msvc-debug",
      "displayName": "MSVC Debug",
      "description": "Windows MSVC Debug 编译 (x64)",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build/msvc-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "mingw-release",
      "displayName": "MinGW Release",
      "description": "Windows MinGW-w64 Release 编译",
      "generator": "MinGW Makefiles",
      "binaryDir": "${sourceDir}/build/mingw-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_C_COMPILER": "gcc",
        "CMAKE_CXX_COMPILER": "g++"
      }
    },
    {
      "name": "mingw-debug",
      "displayName": "MinGW Debug",
      "description": "Windows MinGW-w64 Debug 编译",
      "generator": "MinGW Makefiles",
      "binaryDir": "${sourceDir}/build/mingw-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_C_COMPILER": "gcc",
        "CMAKE_CXX_COMPILER": "g++"
      }
    },
    {
      "name": "gcc-release",
      "displayName": "GCC Release (Linux)",
      "description": "Linux GCC Release 编译",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build/gcc-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_C_COMPILER": "gcc",
        "CMAKE_CXX_COMPILER": "g++"
      }
    },
    {
      "name": "gcc-debug",
      "displayName": "GCC Debug (Linux)",
      "description": "Linux GCC Debug 编译",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build/gcc-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_C_COMPILER": "gcc",
        "CMAKE_CXX_COMPILER": "g++"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "msvc-release",
      "configurePreset": "msvc-release",
      "jobs": 4
    },
    {
      "name": "msvc-debug",
      "configurePreset": "msvc-debug",
      "jobs": 4
    },
    {
      "name": "mingw-release",
      "configurePreset": "mingw-release",
      "jobs": 4
    },
    {
      "name": "mingw-debug",
      "configurePreset": "mingw-debug",
      "jobs": 4
    },
    {
      "name": "gcc-release",
      "configurePreset": "gcc-release",
      "jobs": 4
    },
    {
      "name": "gcc-debug",
      "configurePreset": "gcc-debug",
      "jobs": 4
    }
  ]
}
